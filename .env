# Copy this file to .env and fill in your actual keys.
# .env is gitignored and never committed.

# ── Text LLM ─────────────────────────────────────────────────────────────────
# DeepSeek (recommended, free tier available at https://platform.deepseek.com)
LLM_API_KEY=sk-xxxxxxxxxxxxxxxxxxxx
LLM_BASE_URL=https://api.deepseek.com
LLM_MODEL=deepseek-chat

# ── Vision LLM (for mold drawing image analysis) ────────────────────────────
# Qwen-VL (free tier via Aliyun DashScope: https://dashscope.aliyuncs.com)
VISION_API_KEY=sk-xxxxxxxxxxxxxxxxxxxx
VISION_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
VISION_MODEL=qwen-vl-max

# ── Optional: SerpAPI for more reliable web search ──────────────────────────
# SERPAPI_KEY=xxxxxxxxxxxxxxxxxxxx

# ── Debug mode ───────────────────────────────────────────────────────────────
# DEBUG=false
